# =============================================================================
# .dev.vars — Server-side secrets for Cloudflare Workers
# These are NOT exposed to the browser. Used by wrangler for local dev.
# Copy this file to .dev.vars and fill in the values you need.
# =============================================================================

# --- Google OAuth (feature flag: auth) ---
# Get these from: Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Creem Payments (feature flag: payments) ---
# Get these from: creem.io > Dashboard > API Keys / Webhooks
# Test keys start with creem_test_, production keys start with creem_
CREEM_API_KEY=
CREEM_WEBHOOK_SECRET=
# Product IDs from Creem Dashboard > Products (same ID format for test and production)
CREEM_PRODUCT_ID_STARTER=
CREEM_PRODUCT_ID_PRO=

# --- Replicate AI (feature flag: ai) ---
# Get this from: replicate.com > Account > API tokens
REPLICATE_API_TOKEN=

# --- Resend Email Alerts (optional, no feature flag) ---
# Get this from: resend.com > API Keys
RESEND_API_KEY=
# Email address to receive error alerts (leave empty to disable)
ALERT_EMAIL=

# --- Cloudflare Turnstile (feature flag: turnstile) ---
# Get this from: Cloudflare Dashboard > Turnstile > your site > Secret Key
TURNSTILE_SECRET_KEY=

# --- R2 File Upload (feature flag: upload) ---
# Get these from: Cloudflare Dashboard > R2 > API Tokens > Account API Tokens
# R2_ENDPOINT is the S3 API URL shown on the R2 overview page
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
